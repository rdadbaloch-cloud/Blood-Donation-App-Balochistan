rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Donors Collection
    match /donors/{donorId} {
      allow read: if true; // Public searchable
      
      allow create: if true; // Allow anyone to register
      allow update: if true; // Allow admin panel to update (without FB Auth)
      allow delete: if true; // Allow admin panel to delete (without FB Auth)
    }

    // Emergency Requests
    match /emergency_requests/{requestId} {
      allow read: if true;
      allow write: if true;
    }

    // Districts Collection
    match /districts/{districtId} {
      allow read: if true;
      allow write: if true;
    }

    // Admin Access (Firebase Auth based - kept for legacy or future real auth)
    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if false;
    }
  }
}
